{
  "compilerOptions": {
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "bundler",
    "strict": false,
    "strictNullChecks": true,
    "skipLibCheck": true
  },
  "include": ["*.js", "tests/**/*.js"],
  "exclude": ["node_modules", "dist", "scripts"]
}
